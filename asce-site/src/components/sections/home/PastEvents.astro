---
type PastEvent = {
	title: string;
	dateLabel: string;
	imageSrc: string;
	imageAlt: string;
	description: string;
};

const events: PastEvent[] = [
	{
		title: 'ASCE-Bear, Where Are You?',
		dateLabel: 'November 21, 2025',
		imageSrc: '/images/full-image-nov-21.jpg',
		imageAlt: 'Event poster for “ASCE-Bear, Where Are You?”',
		description:
			'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius eu metus et scelerisque. Nullam gravida eu elit et rutrum. Sed congue elementum placerat. Maecenas nec rhoncus est.',
	},
	{
		title: 'The Rise of ASCE Bear',
		dateLabel: 'February 20, 2026',
		imageSrc: '/images/full-image-feb-20.jpg',
		imageAlt: 'Event poster for “The Rise of ASCE Bear”',
		description:
			'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius eu metus et scelerisque. Nullam gravida eu elit et rutrum. Sed congue elementum placerat. Maecenas nec rhoncus est.',
	},
	{
		title: 'My Little ASCE Bear',
		dateLabel: 'April 3, 2026',
		imageSrc: '/images/full-image-apr-03.png',
		imageAlt: 'Event poster for “My Little ASCE Bear”',
		description:
			'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius eu metus et scelerisque. Nullam gravida eu elit et rutrum. Sed congue elementum placerat. Maecenas nec rhoncus est.',
	},
];
---

<section aria-labelledby="past-events-heading" class="bg-white">
	<div class="w-full px-4 py-10 sm:px-[75px] sm:py-14">
		<h2 id="past-events-heading" class="font-athiti text-[32px] font-semibold leading-[1.28] text-neutral-900 sm:text-[40px]">
			Past Events
		</h2>

		<div class="mt-5 rounded-2xl border-2 border-neutral-300 p-5 sm:mt-6 sm:p-8">
			<div class="grid grid-cols-1 gap-8 sm:grid-cols-3 sm:gap-12">
				{
					events.map((ev) => (
						<article class="overflow-hidden rounded-xl border-2 border-neutral-200 bg-white">
							<img
								src={ev.imageSrc}
								alt={ev.imageAlt}
								class="block aspect-[7/6] w-full object-cover object-top"
								loading="lazy"
								decoding="async"
							/>
							<div class="px-5 pb-6 pt-5 text-center">
								<h3 class="font-poppins text-[18px] font-medium leading-[1.28] tracking-normal text-neutral-900 sm:text-[20px]">
									{ev.title}
								</h3>
								<p class="font-poppins mt-2 text-[16px] font-light leading-[1.28] tracking-normal text-neutral-600 sm:text-[18px]">
									{ev.dateLabel}
								</p>
								<p class="font-poppins mt-4 text-pretty text-[13px] font-normal leading-[1.61] tracking-[-0.01em] text-neutral-700 sm:text-[14px]">
									{ev.description}
								</p>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</div>
</section>

