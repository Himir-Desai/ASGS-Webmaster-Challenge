---
import OpenableInfoCard from '../../elements/OpenableInfoCard.tsx';

type PastEvent = {
	title: string;
	dateLabel: string;
	imageSrc: string;
	imageAlt: string;
	description: string;
	details: string;
};

const events: PastEvent[] = [
	{
		title: 'ASCE-Bear, Where Are You?',
		dateLabel: 'November 21, 2025',
		imageSrc: '/images/full-image-nov-21.jpg',
		imageAlt: 'Event poster for “ASCE-Bear, Where Are You?”',
		description:
			'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius eu metus et scelerisque. Nullam gravida eu elit et rutrum. Sed congue elementum placerat. Maecenas nec rhoncus est.',
		details:
			'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse potenti. Donec porttitor tempor pulvinar.\n\nSed congue elementum placerat. Vivamus sagittis ullamcorper quam, sit amet tincidunt enim sollicitudin ut.\n\nInteger tempor enim lacus, sit amet dapibus diam elementum et. Praesent ac augue vitae turpis ullamcorper.',
	},
	{
		title: 'The Rise of ASCE Bear',
		dateLabel: 'February 20, 2026',
		imageSrc: '/images/full-image-feb-20.jpg',
		imageAlt: 'Event poster for “The Rise of ASCE Bear”',
		description:
			'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius eu metus et scelerisque. Nullam gravida eu elit et rutrum. Sed congue elementum placerat. Maecenas nec rhoncus est.',
		details:
			'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aenean euismod mattis quam porttitor ornare.\n\nNulla ac dolor nibh. Vestibulum feugiat convallis posuere. Pellentesque vestibulum eleifend turpis vel consequat.\n\nMorbi malesuada sodales urna, quis pulvinar nunc interdum ultrices.',
	},
	{
		title: 'My Little ASCE Bear',
		dateLabel: 'April 3, 2026',
		imageSrc: '/images/full-image-apr-03.png',
		imageAlt: 'Event poster for “My Little ASCE Bear”',
		description:
			'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius eu metus et scelerisque. Nullam gravida eu elit et rutrum. Sed congue elementum placerat. Maecenas nec rhoncus est.',
		details:
			'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Cras tempor turpis in nunc finibus sollicitudin.\n\nFusce et sagittis magna, in feugiat felis. Sed volutpat, risus id ultricies blandit, arcu elit consectetur tellus.\n\nUt fringilla eleifend mollis. Phasellus in dui tellus.',
	},
];
---

<section aria-labelledby="past-events-heading" class="bg-white">
	<div class="section-shell">
		<h2
			id="past-events-heading"
			class="font-athiti text-[32px] font-semibold leading-[1.28] text-neutral-900 sm:text-[40px]"
		>
			Past Events
		</h2>

		<div class="mt-5 rounded-2xl border-2 border-neutral-300 p-5 sm:mt-6 sm:p-8">
			<div class="grid grid-cols-1 gap-8 sm:grid-cols-3 sm:gap-12">
				{
					events.map((ev) => (
						<OpenableInfoCard
							client:idle
							title={ev.title}
							subtitle={ev.dateLabel}
							imageSrc={ev.imageSrc}
							imageAlt={ev.imageAlt}
							summary={ev.description}
							details={ev.details}
						/>
					))
				}
			</div>
		</div>
	</div>
</section>

