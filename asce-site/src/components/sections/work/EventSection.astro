---
interface Props {
	title: string;
	dateLabel: string;
	imageSrc: string;
	imageAlt: string;
	description: string;
	details: string;
}

const { title, dateLabel, imageSrc, imageAlt, description, details } = Astro.props;

const detailParagraphs = details.split('\n\n').filter(Boolean);
---

<section
	aria-label={title}
	class="card-interactive rounded-2xl border-2 border-neutral-200 bg-white p-6 sm:p-8"
>
	<div class="grid grid-cols-1 gap-6 lg:grid-cols-[320px_1fr] lg:items-start">
		<div class="overflow-hidden rounded-xl border-2 border-neutral-200 bg-neutral-50">
			<img
				src={imageSrc}
				alt={imageAlt}
				loading="lazy"
				decoding="async"
				class="card-image-zoom h-auto w-full object-cover"
			/>
		</div>

		<div class="min-w-0">
			<p class="font-poppins text-xs font-semibold uppercase tracking-widest text-neutral-500">
				{dateLabel}
			</p>
			<h3 class="font-athiti mt-2 text-[28px] font-semibold leading-[1.18] text-neutral-900 sm:text-[32px]">
				{title}
			</h3>

			<p class="font-poppins mt-3 text-pretty text-[15px] leading-[1.65] tracking-[-0.01em] text-neutral-700 sm:text-[16px]">
				{description}
			</p>

			<div class="mt-4 space-y-3">
				{detailParagraphs.map((p) => (
					<p class="font-poppins text-pretty text-[14px] leading-[1.7] tracking-[-0.01em] text-neutral-600 sm:text-[15px]">
						{p}
					</p>
				))}
			</div>
		</div>
	</div>
</section>

