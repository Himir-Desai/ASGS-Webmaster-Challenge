---
const instagramUrl = 'https://www.instagram.com/ucsdasce/';
const linkedinUrl = 'https://www.linkedin.com/company/ucsd-associated-students-concerts-and-events';
---

<footer class="border-t border-neutral-200 bg-white">
	<div
		class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-4 px-4 py-4 sm:grid-cols-[1fr_auto_1fr_auto_1fr] sm:items-center sm:gap-x-8 sm:gap-y-0 sm:px-6"
	>
		<div class="flex items-center sm:justify-self-start">
			<p class="max-w-[14rem] text-left text-xs leading-relaxed text-neutral-500">
				Made by Himir Desai for ASGS Webmaster Challenge
			</p>
		</div>

		<span
			class="hidden h-10 w-px justify-self-center bg-neutral-300 sm:block"
			aria-hidden="true">
		</span>

		<div class="flex items-center justify-center sm:justify-self-center">
			<p class="text-sm font-semibold tracking-tight text-neutral-900">ASCE</p>
		</div>

		<span
			class="hidden h-10 w-px justify-self-center bg-neutral-300 sm:block"
			aria-hidden="true">
		</span>

		<div class="flex items-center sm:justify-self-end">
			<nav
				aria-label="Social and contact"
				class="flex w-full flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm sm:w-auto sm:justify-end"
			>
				<a
					href={instagramUrl}
					class="text-neutral-600 underline-offset-4 transition-colors hover:text-neutral-900 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2"
					target="_blank"
					rel="noopener noreferrer"
				>
					Instagram
				</a>
				<a
					href="/contact"
					class="text-neutral-600 underline-offset-4 transition-colors hover:text-neutral-900 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2"
				>
					Email
				</a>
				<a
					href={linkedinUrl}
					class="text-neutral-600 underline-offset-4 transition-colors hover:text-neutral-900 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2"
					target="_blank"
					rel="noopener noreferrer"
				>
					LinkedIn
				</a>
			</nav>
		</div>
	</div>
</footer>
