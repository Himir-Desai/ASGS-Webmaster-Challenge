---
const instagramUrl = 'https://www.instagram.com/ucsdasce/';
const linkedinUrl = 'https://www.linkedin.com/in/Himir-Desai';
const resumeUrl = 'https://drive.google.com/file/d/1FmRCBECxFA9Rc8EwRgkj-WyZV4nzk-73/view?usp=sharing';
---

<footer class="border-t mt-[40px] sm:mt-[56px] border-neutral-200 bg-[#00588C] sm:h-[135px]">
	<div
		class="w-full h-full flex gap-4 sm:px-[50px] px-[25px] py-4 sm:justify-between sm:flex-row flex-col"
	>
		<div class="flex items-center sm:justify-self-start justify-center">
			<p class="sm:text-left text-sm lg:text-base uppercase leading-relaxed text-white">
				Made with ♡ by A.S. Graphic Studio
			</p>
		</div>

		<div class="flex items-center sm:justify-self-end">
			<nav
				aria-label="Social and contact"
				class="flex w-full flex-wrap items-center uppercase justify-center gap-x-[10px] lg:gap-x-[44px] gap-y-2 text-sm lg:text-base sm:w-auto sm:justify-end"
			>
				<a
					href="/ASGS-Webmaster-Challenge/contact"
					class="relative inline-block text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 after:absolute after:left-0 after:-bottom-0.5 after:h-0.5 after:w-0 after:bg-current after:transition-[width] after:duration-300 after:ease-out hover:after:w-full"
				>
					Email
				</a>

				<a
					href={resumeUrl}
					class="relative inline-block text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 after:absolute after:left-0 after:-bottom-0.5 after:h-0.5 after:w-0 after:bg-current after:transition-[width] after:duration-300 after:ease-out hover:after:w-full"
				>
					Resume
				</a>

				<a
					href={instagramUrl}
					class="relative inline-block text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 after:absolute after:left-0 after:-bottom-0.5 after:h-0.5 after:w-0 after:bg-current after:transition-[width] after:duration-300 after:ease-out hover:after:w-full"
					target="_blank"
					rel="noopener noreferrer"
				>
					Instagram
				</a>

				<a
					href={linkedinUrl}
					class="relative inline-block text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 after:absolute after:left-0 after:-bottom-0.5 after:h-0.5 after:w-0 after:bg-current after:transition-[width] after:duration-300 after:ease-out hover:after:w-full"
					target="_blank"
					rel="noopener noreferrer"
				>
					LinkedIn
				</a>
			</nav>
		</div>
	</div>
</footer>
