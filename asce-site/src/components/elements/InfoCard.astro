---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<article class="card-interactive rounded-xl border-2 border-neutral-200 bg-white p-6">
	<h3 class="font-athiti text-[24px] font-semibold leading-[1.28] text-neutral-900">{title}</h3>
	<div class="font-poppins mt-3 text-pretty text-[14px] font-normal leading-[1.61] tracking-[-0.01em] text-neutral-700">
		<slot />
	</div>
</article>

