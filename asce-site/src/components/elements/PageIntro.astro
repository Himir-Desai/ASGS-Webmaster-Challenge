---
interface Props {
	ariaLabel: string;
	title: string;
}

const { ariaLabel, title } = Astro.props;
---

<section aria-label={ariaLabel} class="bg-white">
	<div class="section-shell">
		<div class="mx-auto w-full max-w-6xl">
			<div class="max-w-4xl">
				<h1 class="font-athiti text-[40px] font-semibold leading-[1.12] tracking-normal text-neutral-900 sm:text-[52px]">
					{title}
				</h1>
				<slot />
			</div>

			<slot name="after" />
		</div>
	</div>
</section>

