---

<BaseLayout title="Home">
	<main id="main" class="min-h-0 flex-1 outline-none">
		<div class="w-full">
			<HeroCarousel client:load />
		</div>

		<section aria-label="Bear Gardens intro" class="bg-white">
			<div class="section-shell">
				<div class="text-center">
					<p class="font-athiti text-pretty text-[24px] font-normal leading-[1.28] tracking-normal text-neutral-800 sm:text-[36px]">
						{bearGardensTitle}
					</p>
					<p class="font-poppins mt-4 text-pretty text-[16px] font-normal leading-[1.61] tracking-[-0.01em] text-neutral-600 sm:mt-6 sm:text-[20px]">
						{bearGardensBody}
					</p>
				</div>
			</div>
		</section>

		<section aria-labelledby="past-events-heading" class="bg-white">
			<div class="section-shell">
				<h2
					id="past-events-heading"
					class="font-athiti text-[32px] font-semibold leading-[1.28] text-neutral-900 sm:text-[40px]"
				>
					Past Events
				</h2>

				<div class="mt-5 rounded-2xl border-2 border-neutral-300 p-5 sm:mt-6 sm:p-8">
					<div class="grid grid-cols-1 gap-8 sm:grid-cols-3 sm:gap-12">
						{
							pastEvents.map((ev) => (
								<OpenableInfoCard
									client:idle
									title={ev.title}
									subtitle={ev.dateLabel}
									imageSrc={ev.imageSrc}
									imageAlt={ev.imageAlt}
									summary={ev.description}
									details={ev.details}
								/>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<section aria-label="Bear Garden details" class="bg-white">
			<div class="section-shell">
				<div class="hidden grid-cols-2 gap-x-24 gap-y-16 sm:grid">
					{
						bearGardenDetails.map((d) => (
							<div>
								<h3 class="font-athiti text-[24px] font-semibold leading-[1.28] tracking-normal text-neutral-900">
									{d.title}
								</h3>
								<p class="font-poppins mt-4 text-[18px] font-normal leading-[1.61] tracking-[-0.01em] text-neutral-700">
									{d.body}
								</p>
							</div>
						))
					}
				</div>

				<div class="sm:hidden">
					<div class="divide-y divide-neutral-200 rounded-xl border-2 border-neutral-200">
						{
							bearGardenDetails.map((d) => (
								<details class="group px-4 py-4">
									<summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-athiti text-[24px] font-semibold leading-[1.28] text-neutral-900">
										<span>{d.title}</span>
										<span aria-hidden="true" class="text-neutral-500 transition-transform group-open:rotate-180">
											▾
										</span>
									</summary>
									<div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out motion-reduce:transition-none group-open:grid-rows-[1fr]">
										<div class="overflow-hidden">
											<p class="font-poppins mt-3 translate-y-1 text-[18px] font-normal leading-[1.61] tracking-[-0.01em] text-neutral-700 opacity-0 transition-[opacity,transform] duration-200 ease-out motion-reduce:transition-none group-open:translate-y-0 group-open:opacity-100">
												{d.body}
											</p>
										</div>
									</div>
								</details>
							))
						}
					</div>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>
