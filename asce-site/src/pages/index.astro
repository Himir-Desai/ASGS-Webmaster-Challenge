---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/sections/home/HeroCarousel.tsx';
---

<BaseLayout title="Home">
	<main id="main" class="min-h-0 flex-1 outline-none">
		<div class="relative left-1/2 w-screen -translate-x-1/2">
			<HeroCarousel client:load />
		</div>
		<section class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6">
			<p class="text-neutral-600">Home — layout shell ready. Sections will mount here as React islands.</p>
		</section>
	</main>
</BaseLayout>
