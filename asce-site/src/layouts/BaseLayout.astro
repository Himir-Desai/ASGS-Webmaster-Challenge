---
import '../styles/global.css';
import SiteFooter from '../components/layout/SiteFooter.astro';
import SiteHeader from '../components/layout/SiteHeader.tsx';

interface Props {
	title: string;
	description?: string;
}

const { title, description = 'ASGS — accessible, responsive site.' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="flex min-h-dvh flex-col bg-white text-neutral-900 antialiased">
		<a class="skip-link" href="#main">Skip to main content</a>
		<div class="flex min-h-0 min-w-0 flex-1 flex-col">
			<SiteHeader client:load />
			<slot />
			<SiteFooter />
		</div>
	</body>
</html>
